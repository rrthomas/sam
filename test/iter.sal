// List iterator
for i in [1, 2, 42, 5.0] {
    debug(i)
}

// Int iterator
for i in 7 {
    debug(i)
}

// 'null' iterator
for i in null {
    debug(i)
}

// Modify a list while iterating
let l = [1, 2.0, 3.4, 5]
for i in l {
    <<<l
    debug(i)
}

// Modify a map while itering
let m = [1: 4.0, 2: 3.0]
for k in m {
    m[k] := m[k] * 2.0
}
m

// Print a string a grapheme at a time
for g in "γεια σου, ρόζα" {
    log(g)
}

let f = fn(n) {
    return fn() {
        if n == 1 {
            n := null
        } else if n % 2 == 0 {
            n := n / 2
        } else {
            n := n * 3 + 1
        }
        return n
    }
}

for n in f(3) {
    debug(n)
}
